# ── LLM Provider ──────────────────────────
# Choose: openai | xai | claude | gemini | deepseek | zai
LLM_PROVIDER=openai
LLM_MODEL=latest  # latest|auto|default or explicit model ID

# ── Provider Credentials (set the one matching your provider) ──
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional alternative for Claude subscription-style auth:
ANTHROPIC_AUTH_TOKEN=
# Optional override; defaults to official Anthropic endpoint:
ANTHROPIC_BASE_URL=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ZAI_API_KEY=

# ── Telegram ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated user IDs, empty = allow all

# ── Memory ───────────────────────────────
MEMORY_DB_PATH=.CodeClaw/CodeClaw.db
MEMORY_TOP_K=5

# ── Workspace & Context ──────────────────
WORKSPACE_PATH=.CodeClaw/workspace  # path to SOUL.md, IDENTITY.md, USER.md
CONTEXT_WINDOW=128000            # max context tokens before summarization
MAX_OUTPUT_TOKENS=12000          # max generation tokens (important for long code/files)
CodeClaw_DANGER_ACK=            # set to yes to bypass interactive safety confirmation during onboarding
LOCAL_AGENT_TIMEOUT_SEC=1800     # timeout for delegated local coding agents (in seconds)
LOCAL_AGENT_PROGRESS_INTERVAL_SEC=30  # live summarized delegation updates cadence (seconds, min 10)
LOCAL_AGENT_SAFETY_MODE=off      # off|strict (strict blocks destructive delegated tasks)
LOCAL_AGENT_DENY_PATTERNS=       # optional regex list, separated by comma/semicolon/newline
LOCAL_AGENT_MULTI_DEFAULT_AGENTS=claude,codex  # ordered defaults used by /agent multi auto mode
LOCAL_AGENT_MULTI_AUTO_CONTINUE=no  # yes|no (yes skips plan confirmation gate)

# ── Skills ───────────────────────────────
SKILLS_HUB_BASE_URL=https://clawhub.ai
SKILLS_STATE_PATH=.CodeClaw/skills_state.json

# ── Logging (optional) ───────────────────
JSON_LOG_ENABLED=0                # 1/true/yes/on to write structured JSONL logs
JSON_LOG_PATH=.CodeClaw/logs/CodeClaw.jsonl

# ── Voice Transcription (optional) ───────
# Set to enable voice message transcription via Groq Whisper:
GROQ_API_KEY=
