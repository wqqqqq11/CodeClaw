#!/usr/bin/env python3
"""
CodeClaw CLI

命令：
- CodeClaw onboard : 在用户主目录初始化运行时文件。
- CodeClaw run     : 使用用户主目录作为运行时主目录运行机器人。
- CodeClaw chat    : 在终端中聊天，使用与 Telegram 相同的大脑。
"""

from __future__ import annotations

import asyncio
import argparse
import getpass
import logging
import os
import re
import shlex
import shutil
import sys
from pathlib import Path

from dotenv import load_dotenv


PROJECT_ROOT = Path(__file__).resolve().parent
RUNTIME_DIRNAME = ".CodeClaw"
RUNTIME_WORKSPACE = f"{RUNTIME_DIRNAME}/workspace"
RUNTIME_DB = f"{RUNTIME_DIRNAME}/CodeClaw.db"
TEMPLATE_FILES = ("IDENTITY.md", "SOUL.md", "USER.md", "HEARTBEAT.md")
RUN_PROVIDER_AUTH_ENVS = {
    "openai": ("OPENAI_API_KEY",),
    "xai": ("XAI_API_KEY",),
    "claude": ("ANTHROPIC_API_KEY", "ANTHROPIC_AUTH_TOKEN"),
    "gemini": ("GEMINI_API_KEY",),
    "deepseek": ("DEEPSEEK_API_KEY",),
    "zai": ("ZAI_API_KEY",),
}
RUN_PROVIDER_MODELS = {
    "openai": ["gpt-5.2", "gpt-5.2-mini"],
    "xai": ["grok-4-latest", "grok-4-fast-non-reasoning"],
    "claude": ["claude-opus-4-5", "claude-sonnet-4-5"],
    "gemini": ["gemini-3-flash-preview", "gemini-2.5-flash"],
    "deepseek": ["deepseek-chat", "deepseek-reasoner"],
    "zai": ["glm-5", "glm-4.7"],
}
DANGER_ACK_ENV = "CodeClaw_DANGER_ACK"


def _resolve_home(path_arg: str | None) -> Path:
    if path_arg:
        return Path(path_arg).expanduser().resolve()
    return Path.home().resolve()


def _danger_ack_enabled() -> bool:
    value = os.getenv(DANGER_ACK_ENV, "").strip().lower()
    return value in {"yes", "y", "1", "true", "on"}


def _confirm_danger_ack() -> bool:
    """在 onboarding 之前需要显式确认。"""
    if _danger_ack_enabled():
        return True

    print("")
    print("⚠️  CodeClaw 安全通知")
    print("CodeClaw 可以执行受模型影响的文件更改，如果启用，还可以执行本地代理命令。")
    print("它没有经过正式的安全审计。")
    print("请使用最小权限，审查技能/提示，并在隔离环境中运行。")
    print("")
    if not sys.stdin.isatty():
        print(
            f"检测到非交互式会话。设置 {DANGER_ACK_ENV}=yes 以继续，"
            "或以交互方式运行并输入 yes。"
        )
        return False

    answer = input("输入 'yes' 以继续: ").strip().lower()
    if answer != "yes":
        print("安全确认未被接受。正在退出。")
        return False
    return True


def _configured_run_providers() -> list[str]:
    configured: list[str] = []
    for provider, env_keys in RUN_PROVIDER_AUTH_ENVS.items():
        if any(os.getenv(key, "").strip() for key in env_keys):
            configured.append(provider)
    return configured


def _pick_number(prompt: str, max_value: int, default_value: int) -> int:
    raw = input(prompt).strip()
    if not raw:
        return default_value
    try:
        value = int(raw)
    except ValueError:
        return default_value
    if 1 <= value <= max_value:
        return value
    return default_value


def _prompt_run_provider_model(current_provider: str, current_model: str) -> tuple[str, str]:
    if not sys.stdin.isatty():
        return "", ""

    available = _configured_run_providers()
    if not available:
        return "", ""

    if current_provider in available:
        suggested_model = current_model or RUN_PROVIDER_MODELS.get(
            current_provider, ["latest"]
        )[0]
        print("")
        answer = input(
            f"继续使用当前的提供商/模型 ({current_provider} / {suggested_model})? [Y/n]: "
        ).strip().lower()
        if answer in {"", "y", "yes", "ok"}:
            print(f"此次运行使用 {current_provider} ({suggested_model})。")
            print("提示：对于自定义模型 ID，请直接在 .env 中设置 LLM_MODEL。")
            return current_provider, suggested_model

    print("")
    if len(available) == 1:
        selected_provider = available[0]
        print(f"此次运行的提供商: {selected_provider}")
    else:
        print("为此次运行选择提供商：")
        for idx, provider in enumerate(available, start=1):
            marker = " (当前)" if provider == current_provider else ""
            default_model = RUN_PROVIDER_MODELS.get(provider, ["latest"])[0]
            print(f"  {idx}) {provider} ({default_model}){marker}")

        default_provider_idx = (
            available.index(current_provider) + 1 if current_provider in available else 1
        )
        provider_idx = _pick_number(
            f"Provider [{default_provider_idx}]: ",
            max_value=len(available),
            default_value=default_provider_idx,
        )
        selected_provider = available[provider_idx - 1]

    models = RUN_PROVIDER_MODELS.get(selected_provider, ["latest"])
    print(f"\n为 {selected_provider} 选择模型：")
    for idx, model in enumerate(models, start=1):
            marker = " (当前)" if selected_provider == current_provider and model == current_model else ""
        print(f"  {idx}) {model}{marker}")

    default_model_idx = 1
    if selected_provider == current_provider and current_model in models:
        default_model_idx = models.index(current_model) + 1

    model_idx = _pick_number(
        f"模型 [{default_model_idx}]: ",
        max_value=len(models),
        default_value=default_model_idx,
    )
    selected_model = models[model_idx - 1]

    print(f"\n此次运行使用 {selected_provider} ({selected_model})。")
    print("提示：对于自定义模型 ID，请直接在 .env 中设置 LLM_MODEL。")
    return selected_provider, selected_model


def _patched_env_example() -> str:
    template_path = PROJECT_ROOT / ".env.example"
    if template_path.exists():
        content = template_path.read_text(encoding="utf-8")
    else:
        content = (
            "LLM_PROVIDER=openai\n"
            "LLM_MODEL=latest\n"
            "OPENAI_API_KEY=\n"
            "ANTHROPIC_API_KEY=\n"
            "ANTHROPIC_AUTH_TOKEN=\n"
            "ANTHROPIC_BASE_URL=\n"
            "DEEPSEEK_API_KEY=\n"
            "TELEGRAM_BOT_TOKEN=\n"
            f"MEMORY_DB_PATH={RUNTIME_DB}\n"
            f"WORKSPACE_PATH={RUNTIME_WORKSPACE}\n"
            "CONTEXT_WINDOW=128000\n"
        )

    if re.search(r"(?m)^MEMORY_DB_PATH=", content):
        content = re.sub(r"(?m)^MEMORY_DB_PATH=.*$", f"MEMORY_DB_PATH={RUNTIME_DB}", content)
    else:
        content += f"\nMEMORY_DB_PATH={RUNTIME_DB}\n"

    if re.search(r"(?m)^WORKSPACE_PATH=", content):
        content = re.sub(r"(?m)^WORKSPACE_PATH=.*$", f"WORKSPACE_PATH={RUNTIME_WORKSPACE}", content)
    else:
        content += f"\nWORKSPACE_PATH={RUNTIME_WORKSPACE}\n"

    return content


def _upgrade_legacy_env_defaults(content: str) -> tuple[str, bool]:
    """将旧版默认路径升级到运行时默认值（仅非自定义值）。"""
    updated = content
    changed = False

    workspace_patterns = [
        r"(?m)^WORKSPACE_PATH\s*=\s*workspace\s*(?:#.*)?$",
        r"(?m)^WORKSPACE_PATH\s*=\s*\./workspace\s*(?:#.*)?$",
    ]
    memory_patterns = [
        r"(?m)^MEMORY_DB_PATH\s*=\s*CodeClaw\.db\s*(?:#.*)?$",
        r"(?m)^MEMORY_DB_PATH\s*=\s*\./CodeClaw\.db\s*(?:#.*)?$",
    ]

    for pattern in workspace_patterns:
        new_text, count = re.subn(pattern, f"WORKSPACE_PATH={RUNTIME_WORKSPACE}", updated)
        if count:
            changed = True
            updated = new_text

    for pattern in memory_patterns:
        new_text, count = re.subn(pattern, f"MEMORY_DB_PATH={RUNTIME_DB}", updated)
        if count:
            changed = True
            updated = new_text

    return updated, changed


def _migrate_legacy_workspace(home: Path, workspace_dir: Path) -> int:
    """如果缺失，将旧版 home/workspace 文件复制到运行时工作区。"""
    legacy = home / "workspace"
    if not legacy.exists() or not legacy.is_dir():
        return 0

    migrated = 0
    for src in legacy.rglob("*"):
        if not src.is_file():
            continue
        rel = src.relative_to(legacy)
        dst = workspace_dir / rel
        if dst.exists():
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
        migrated += 1

    return migrated


def _copy_tree_missing(src_dir: Path, dst_dir: Path) -> int:
    """将文件从 src 复制到 dst，跳过任何已存在的文件。"""
    if not src_dir.exists() or not src_dir.is_dir():
        return 0

    copied = 0
    for src in src_dir.rglob("*"):
        if not src.is_file():
            continue
        rel = src.relative_to(src_dir)
        dst = dst_dir / rel
        if dst.exists():
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
        copied += 1
    return copied


def _migrate_legacy_runtime_layout(runtime_dir: Path, workspace_dir: Path) -> tuple[int, int]:
    """将旧版个性文件和技能从 workspace/ 迁移到运行时根目录。"""
    personality_moved = 0
    for filename in TEMPLATE_FILES:
        src = workspace_dir / filename
        dst = runtime_dir / filename
        if not src.exists():
            continue
        if dst.exists():
            # 如果两者都存在且内容匹配，删除旧版副本以保持工作区清洁。
            try:
                if src.read_text(encoding="utf-8") == dst.read_text(encoding="utf-8"):
                    src.unlink(missing_ok=True)
                continue
            except Exception:
                continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(str(src), str(dst))
        personality_moved += 1

    legacy_skills = workspace_dir / "skills"
    runtime_skills = runtime_dir / "skills"
    skills_moved = 0
    if legacy_skills.exists() and legacy_skills.is_dir():
        if not runtime_skills.exists():
            shutil.move(str(legacy_skills), str(runtime_skills))
            skills_moved = sum(1 for p in runtime_skills.rglob("*") if p.is_file())
        else:
            skills_moved = _copy_tree_missing(legacy_skills, runtime_skills)

    return personality_moved, skills_moved


def _ensure_workspace_templates(runtime_dir: Path, force: bool) -> list[str]:
    """确保工作区模板存在。"""
    created: list[str] = []
    source_workspace = PROJECT_ROOT / "templates" / "personality"
    if not source_workspace.exists():
        source_workspace = PROJECT_ROOT / "workspace"

    defaults = {
        "IDENTITY.md": "# CodeClaw\n\n一个专注的个人 AI 助手。",
        "SOUL.md": "# 灵魂\n\n乐于助人、准确、简洁。",
        "USER.md": "# 用户\n\n个人偏好放在这里。",
        "HEARTBEAT.md": (
            "# 心跳\n\n"
            "每隔一段时间运行并发送简短的主动更新。\n\n"
            "规则\n"
            "- 保持更新简洁有用。\n"
            "- 如果没有有意义的更新，回复 NO_UPDATE。\n"
        ),
    }

    for filename in TEMPLATE_FILES:
        target = runtime_dir / filename
        if target.exists() and not force:
            continue

        source = source_workspace / filename
        if source.exists():
            content = source.read_text(encoding="utf-8")
        else:
            content = defaults[filename]

        target.write_text(content, encoding="utf-8")
        created.append(filename)

    return created


def _confirm_reset_env(env_path: Path) -> bool:
    """当 onboarding 重新运行时询问是否重置 .env。"""
    if not sys.stdin.isatty():
        return False
    print("")
    print(f"找到现有配置: {env_path}")
    print("你想现在从最新模板重置 .env 吗？")
    answer = input("重置 .env? [y/N]: ").strip().lower()
    return answer in {"y", "yes"}


def _set_env_value(content: str, key: str, value: str) -> str:
    line = f"{key}={value}"
    pattern = rf"(?m)^{re.escape(key)}=.*$"
    if re.search(pattern, content):
        return re.sub(pattern, line, content)
    suffix = "" if content.endswith("\n") else "\n"
    return f"{content}{suffix}{line}\n"


def _get_env_value(content: str, key: str) -> str:
    match = re.search(rf"(?m)^{re.escape(key)}=(.*)$", content)
    if not match:
        return ""
    value = (match.group(1) or "").strip()
    if not value:
        return ""
    # Treat comment placeholders as empty and strip inline comments.
    if value.startswith("#"):
        return ""
    return re.sub(r"\s+#.*$", "", value).strip()


def _clear_other_provider_keys(content: str, keep_keys: set[str] | None = None) -> str:
    keep_keys = keep_keys or set()
    provider_keys = (
        "OPENAI_API_KEY",
        "XAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "ANTHROPIC_AUTH_TOKEN",
        "GEMINI_API_KEY",
        "DEEPSEEK_API_KEY",
        "ZAI_API_KEY",
    )
    updated = content
    for key in provider_keys:
        if key in keep_keys:
            continue
        updated = _set_env_value(updated, key, "")
    return updated


def _read_secret(prompt: str) -> str:
    """读取密码输入，为非标准终端提供回退方案。"""
    try:
        return getpass.getpass(prompt).strip()
    except Exception:
        try:
            return input(prompt).strip()
        except EOFError:
            return ""


def _configure_env_interactive(
    env_path: Path,
    force_prompt: bool = False,
    fallback_content: str = "",
) -> bool:
    """可选的引导式提供商/令牌设置用于 .env。"""
    if not sys.stdin.isatty():
        return False

    if not force_prompt:
        answer = input("现在配置提供商和令牌吗? [Y/n]: ").strip().lower()
        if answer in {"n", "no"}:
            return False

    providers = [
        ("openai", "OpenAI", "gpt-5.2"),
        ("xai", "xAI", "grok-4-latest"),
        ("claude", "Anthropic", "claude-opus-4-5"),
        ("gemini", "Google", "gemini-3-flash-preview"),
        ("deepseek", "DeepSeek", "deepseek-chat"),
        ("zai", "Z-AI", "glm-5"),
    ]

    print("")
    print("选择提供商：")
    for idx, (_, name, model) in enumerate(providers, start=1):
        print(f"  {idx}) {name} ({model})")

    content = env_path.read_text(encoding="utf-8")

    def existing_value(key: str) -> str:
        current = _get_env_value(content, key)
        if current:
            return current
        return _get_env_value(fallback_content, key) if fallback_content else ""

    existing_provider = existing_value("LLM_PROVIDER")
    default_provider_idx = None
    for idx, (provider_id, _, _) in enumerate(providers, start=1):
        if provider_id == existing_provider:
            default_provider_idx = idx
            break

    selected = None
    while selected is None:
        default_label = (
            f" [{default_provider_idx}]"
            if default_provider_idx is not None
            else f" [1-{len(providers)}]"
        )
        raw = input(f"提供商编号{default_label}: ").strip()
        if not raw and default_provider_idx is not None:
            choice = default_provider_idx
        else:
            try:
                choice = int(raw)
            except ValueError:
                choice = 0
        if 1 <= choice <= len(providers):
            selected = providers[choice - 1]
        else:
            print(f"无效的选择。请输入 1-{len(providers)}。")

    provider_id, provider_name, default_model = selected
    existing_model = existing_value("LLM_MODEL")
    model_default = (
        existing_model
        if existing_provider == provider_id and existing_model
        else default_model
    )
    model = input(f"模型 [{model_default}]: ").strip() or model_default

    api_key = ""
    anthropic_auth_token = ""
    anthropic_base_url = existing_value("ANTHROPIC_BASE_URL")
    if provider_id == "claude":
        existing_api_key = existing_value("ANTHROPIC_API_KEY")
        existing_auth_token = existing_value("ANTHROPIC_AUTH_TOKEN")
        print("")
        print("Claude 认证模式：")
        print("  1) API 密钥 (ANTHROPIC_API_KEY)")
        print("  2) 认证令牌 / 订阅 (ANTHROPIC_AUTH_TOKEN)")
        default_auth_idx = 2 if existing_auth_token else 1
        auth_idx = _pick_number(
            f"认证模式 [{default_auth_idx}]: ",
            max_value=2,
            default_value=default_auth_idx,
        )
        if auth_idx == 2:
            anthropic_auth_token = _read_secret(
                "ANTHROPIC_AUTH_TOKEN (留空以保持当前值): "
            )
            if not anthropic_auth_token:
                anthropic_auth_token = existing_auth_token
            api_key = ""
        else:
            api_key = _read_secret("ANTHROPIC_API_KEY (留空以保持当前值): ")
            if not api_key:
                api_key = existing_api_key
            anthropic_auth_token = ""

        existing_base_url = existing_value("ANTHROPIC_BASE_URL")
        default_base_url = existing_base_url or "https://api.anthropic.com"
        base_url_raw = input(f"ANTHROPIC_BASE_URL [{default_base_url}]: ").strip()  # 环境变量名保持英文
        anthropic_base_url = base_url_raw or existing_base_url
    else:
        key_env = RUN_PROVIDER_AUTH_ENVS[provider_id][0]
        existing_key = existing_value(key_env)
        api_key = _read_secret(f"{key_env} (留空以保持当前值): ")
        if not api_key:
            api_key = existing_key

    existing_telegram_token = existing_value("TELEGRAM_BOT_TOKEN")
    telegram_token = input("TELEGRAM_BOT_TOKEN (留空以保持当前值): ").strip()
    if not telegram_token:
        telegram_token = existing_telegram_token

    existing_allowed_users = existing_value("TELEGRAM_ALLOWED_USERS")
    allowed_users = input(
        "TELEGRAM_ALLOWED_USERS (可选，逗号分隔，留空保持当前值): "
    ).strip()
    if not allowed_users:
        allowed_users = existing_allowed_users

    content = _set_env_value(content, "LLM_PROVIDER", provider_id)
    content = _set_env_value(content, "LLM_MODEL", model)
    if provider_id == "claude":
        content = _set_env_value(content, "ANTHROPIC_API_KEY", api_key)
        content = _set_env_value(content, "ANTHROPIC_AUTH_TOKEN", anthropic_auth_token)
        content = _set_env_value(content, "ANTHROPIC_BASE_URL", anthropic_base_url)
        content = _clear_other_provider_keys(
            content,
            keep_keys={"ANTHROPIC_API_KEY", "ANTHROPIC_AUTH_TOKEN"},
        )
    else:
        key_env = RUN_PROVIDER_AUTH_ENVS[provider_id][0]
        content = _set_env_value(content, key_env, api_key)
        content = _clear_other_provider_keys(content, keep_keys={key_env})
    content = _set_env_value(content, "TELEGRAM_BOT_TOKEN", telegram_token)
    content = _set_env_value(content, "TELEGRAM_ALLOWED_USERS", allowed_users)

    env_path.write_text(content, encoding="utf-8")
    print(f"- 已应用引导式配置: 提供商={provider_name}, 模型={model}")
    return True


def cmd_onboard(args: argparse.Namespace) -> int:
    home = _resolve_home(args.home)
    runtime_dir = home / RUNTIME_DIRNAME
    workspace_dir = runtime_dir / "workspace"
    env_path = home / ".env"

    if env_path.exists():
        load_dotenv(env_path, override=False)
    if not _confirm_danger_ack():
        return 1

    runtime_dir.mkdir(parents=True, exist_ok=True)
    workspace_dir.mkdir(parents=True, exist_ok=True)

    migrated = _migrate_legacy_workspace(home, workspace_dir)
    migrated_personality, migrated_skills = _migrate_legacy_runtime_layout(
        runtime_dir, workspace_dir
    )
    created_templates = _ensure_workspace_templates(runtime_dir, force=args.force)

    env_existed = env_path.exists()
    previous_env_content = env_path.read_text(encoding="utf-8") if env_existed else ""
    wrote_env = False
    upgraded_env = False
    reset_env = False
    if env_existed and not args.force and not args.reset_env:
        original = env_path.read_text(encoding="utf-8")
        upgraded, changed = _upgrade_legacy_env_defaults(original)
        if changed:
            env_path.write_text(upgraded, encoding="utf-8")
            upgraded_env = True
        elif _confirm_reset_env(env_path):
            env_path.write_text(_patched_env_example(), encoding="utf-8")
            wrote_env = True
            reset_env = True
    else:
        env_path.write_text(_patched_env_example(), encoding="utf-8")
        wrote_env = True
        reset_env = env_existed

    print("CodeClaw onboard 完成")
    print(f"- 主目录: {home}")
    print(f"- 运行时目录: {runtime_dir}")
    print(f"- 工作区: {workspace_dir}")
    print(f"- 个性模板: {runtime_dir}")
    print(f"- 技能根目录: {runtime_dir / 'skills'}")
    print(f"- 数据库: {runtime_dir / 'CodeClaw.db'}")
    if wrote_env and reset_env:
        print(f"- 从模板重置配置: {env_path}")
    elif wrote_env:
        print(f"- 写入配置: {env_path}")
    elif upgraded_env:
        print(f"- 在配置中升级旧版默认值: {env_path}")
    else:
        print(f"- 保留现有配置: {env_path}")
    if created_templates:
        print(f"- 创建模板: {', '.join(created_templates)}")
    else:
        print("- 模板文件已存在")
    if migrated:
        print(f"- 从 ./workspace 迁移了 {migrated} 个旧版文件")
    if migrated_personality:
        print(f"- 从 workspace/ 迁移了 {migrated_personality} 个个性文件")
    if migrated_skills:
        print(f"- 从 workspace/skills/ 迁移了 {migrated_skills} 个技能文件")

    configured = False
    fallback_content = previous_env_content if reset_env else ""
    if args.configure:
        configured = _configure_env_interactive(
            env_path,
            force_prompt=True,
            fallback_content=fallback_content,
        )
    elif wrote_env or reset_env:
        print("")
        configured = _configure_env_interactive(
            env_path,
            force_prompt=False,
            fallback_content=fallback_content,
        )

    print("")
    print("下一步：")
    if configured:
        print("1. 如有需要，审查 .env。")
    else:
        print("1. 编辑 .env 并设置 TELEGRAM_BOT_TOKEN + 提供商凭证。")
    print("2. 运行: CodeClaw run")
    return 0


def _prepare_runtime_environment(
    home: Path,
    provider_override_raw: str,
    model_override_raw: str,
    prompt_selection: bool = True,
) -> int:
    """准备运行时目录，加载环境变量，并应用提供商/模型选择。"""
    runtime_dir = home / RUNTIME_DIRNAME
    workspace_dir = runtime_dir / "workspace"

    runtime_dir.mkdir(parents=True, exist_ok=True)
    workspace_dir.mkdir(parents=True, exist_ok=True)
    _migrate_legacy_workspace(home, workspace_dir)
    _migrate_legacy_runtime_layout(runtime_dir, workspace_dir)
    _ensure_workspace_templates(runtime_dir, force=False)

    env_path = home / ".env"
    if env_path.exists():
        load_dotenv(env_path, override=False)

    current_provider = os.getenv("LLM_PROVIDER", "").strip().lower()
    current_model = os.getenv("LLM_MODEL", "").strip()
    provider_override = (provider_override_raw or "").strip().lower()
    model_override = (model_override_raw or "").strip()

    if provider_override and provider_override not in RUN_PROVIDER_AUTH_ENVS:
        supported = ", ".join(RUN_PROVIDER_AUTH_ENVS.keys())
        print(f"不支持的提供商 '{provider_override}'。支持的: {supported}")
        return 2

    if provider_override:
        required_env_keys = RUN_PROVIDER_AUTH_ENVS[provider_override]
        if not any(os.getenv(key, "").strip() for key in required_env_keys):
            required_hint = " or ".join(required_env_keys)
            print(
                f"提供商 '{provider_override}' 需要在 .env 中设置 {required_hint}。"
                "请先设置它，然后重试。"
            )
            return 2

        os.environ["LLM_PROVIDER"] = provider_override
        if model_override:
            os.environ["LLM_MODEL"] = model_override
        elif provider_override != current_provider or not current_model:
            os.environ["LLM_MODEL"] = RUN_PROVIDER_MODELS.get(provider_override, ["latest"])[0]

    elif model_override:
        os.environ["LLM_MODEL"] = model_override

    elif prompt_selection:
        selected_provider, selected_model = _prompt_run_provider_model(
            current_provider=current_provider,
            current_model=current_model,
        )
        if selected_provider:
            os.environ["LLM_PROVIDER"] = selected_provider
            os.environ["LLM_MODEL"] = selected_model

    os.environ["CodeClaw_HOME"] = str(home)
    workspace_env = os.getenv("WORKSPACE_PATH", "").strip()
    memory_env = os.getenv("MEMORY_DB_PATH", "").strip()
    if not workspace_env or workspace_env in {"workspace", "./workspace"}:
        os.environ["WORKSPACE_PATH"] = RUNTIME_WORKSPACE
    if not memory_env or memory_env in {"CodeClaw.db", "./CodeClaw.db"}:
        os.environ["MEMORY_DB_PATH"] = RUNTIME_DB

    os.chdir(home)
    return 0


def cmd_run(args: argparse.Namespace) -> int:
    home = _resolve_home(args.home)
    prep_code = _prepare_runtime_environment(
        home,
        args.provider or "",
        args.model or "",
        prompt_selection=True,
    )
    if prep_code:
        return prep_code

    from main import main as bot_main

    bot_main()
    return 0


def cmd_chat(args: argparse.Namespace) -> int:
    home = _resolve_home(args.home)
    prep_code = _prepare_runtime_environment(
        home,
        args.provider or "",
        args.model or "",
        prompt_selection=False,
    )
    if prep_code:
        return prep_code

    os.environ["CodeClaw_CHAT_MODE"] = "1"

    from config import load_config
    from core.logging_setup import configure_optional_json_logging
    from core.personality import runtime_root_from_workspace
    from main import CodeClawBot, build_system_prompt, resolve_runtime_path

    # 保持终端聊天清洁：抑制嘈杂的传输/客户端日志。
    logging.getLogger("httpx").setLevel(logging.WARNING)
    logging.getLogger("httpcore").setLevel(logging.WARNING)
    logging.getLogger("openai._base_client").setLevel(logging.WARNING)

    config = load_config()
    config.workspace_path = str(resolve_runtime_path(config.workspace_path))
    config.memory_db_path = str(resolve_runtime_path(config.memory_db_path))
    config.skills_state_path = str(resolve_runtime_path(config.skills_state_path))
    configure_optional_json_logging(runtime_root_from_workspace(config.workspace_path))

    workspace = Path(config.workspace_path)
    workspace.mkdir(parents=True, exist_ok=True)

    if not config.llm_provider:
        print("未配置提供商。请在 .env 中设置 LLM_PROVIDER + 提供商凭证。")
        return 2

    bot = CodeClawBot(config)
    session_id = (args.session or "cli").strip() or "cli"
    cli_user_id = (
        (config.telegram_allowed_users[0] if config.telegram_allowed_users else "cli-user")
    )
    bot._set_file_mode(session_id, "chat")

    print("")
    print(f"🦞 CodeClaw 终端聊天")
    print(f"提供商: {config.llm_provider} ({config.llm_model})")
    print(f"会话: {session_id}")
    print(f"文件模式: {bot._get_file_mode(session_id)} (使用 /mode edit 启用写入)")
    print("输入 /help 查看命令，/exit 退出。")
    print("")

    async def _chat_once(user_text: str) -> str:
        if bot._llm_backoff_active():
            remaining = bot._llm_backoff_remaining_sec()
            wait_hint = f"{remaining}s" if remaining > 0 else "a short while"
            bot.memory.ingest("user", user_text, session_id)
            return (
                f"⚠️ {config.llm_provider} is temporarily unavailable "
                "(quota/billing or rate limit).\n"
                f"Please retry in about {wait_hint}, or top up your provider balance."
            )

        memories = bot.memory.recall(user_text, top_k=config.memory_top_k)
        memories = bot._filter_recalled_memories(memories)
        memories_text = bot.memory.format_memories_for_prompt(memories)

        recent = bot.memory.get_recent(session_id, limit=20)
        recent = bot._clean_orphan_messages(recent)
        recent = bot._filter_recent_context(recent)

        summary = bot._get_session_summary(session_id)
        skills_text = await asyncio.to_thread(bot.skills.prompt_context, session_id)
        file_mode = bot._get_file_mode(session_id)

        system_prompt = build_system_prompt(
            config, bot.personality, memories_text, summary, skills_text
        )
        if file_mode != "edit":
            system_prompt += (
            "\n\n## 聊天模式约束\n"
            "你处于聊天模式（只读）。不要输出用于保存到文件的文件写入指令或围栏代码块。"
            "提供直接的对话式回答。"
            )
        messages = list(recent)
        messages.append({"role": "user", "content": user_text})

        response = None
        max_retries = 2
        for retry in range(max_retries + 1):
            try:
                response = await bot.llm.chat(messages, system_prompt)
                break
            except Exception as e:
                if retry < max_retries and bot._is_context_error(str(e)) and len(messages) > 4:
                    mid = len(messages) // 2
                    messages = (
                        messages[:1]
                        + [{"role": "system", "content": "[Emergency context compression]"}]
                        + messages[mid:]
                    )
                    continue
                response = f"⚠️ Error communicating with {config.llm_provider}: {e}"
                break

        if response is None:
            response = "⚠️ Failed to get a response after retries. Please try again."

        provider_error_response = bot._is_provider_error_text(response)
        if provider_error_response:
            bot._set_llm_backoff()
        else:
            bot._clear_llm_backoff()

        bot.memory.ingest("user", user_text, session_id)

        requested_file_intent = bot._is_file_intent(user_text)
        allow_file_writes = file_mode == "edit" and requested_file_intent
        mode_hint = ""
        if requested_file_intent and file_mode != "edit":
            mode_hint = (
                "ℹ️ 文件写入当前已禁用 (`/mode chat`)。"
                "使用 `/mode edit` 启用工作区更改。"
            )

        file_ops, cleaned_response = await bot._process_file_blocks(
            response,
            allow_file_writes=allow_file_writes,
        )
        if file_mode != "edit":
            cleaned_response = bot._strip_fenced_code_for_chat(cleaned_response)
        repair_ops = (
            await bot._repair_incomplete_html(session_id, user_text, file_ops)
            if allow_file_writes
            else []
        )
        if repair_ops:
            repaired_paths = {op.path for op in repair_ops if op.action != "error"}
            if repaired_paths:
                file_ops = [op for op in file_ops if op.path not in repaired_paths]
            file_ops.extend(repair_ops)

        success_ops = [op for op in file_ops if op.action != "error" and op.path]
        if success_ops:
            bot._last_file_by_session[session_id] = success_ops[-1].path

        workspace_label = bot._workspace_display_path()
        visible_response = cleaned_response
        if file_ops:
            success_count = sum(1 for op in file_ops if op.action != "error")
            if success_count > 0:
                visible_response = "Done. Saved requested changes to files."
            else:
                visible_response = bot._compact_response_for_file_ops(cleaned_response)

        response_parts = [visible_response] if visible_response else []
        if file_ops:
            response_parts.append(
                bot._render_file_operations(
                    file_ops,
                    include_diffs=False,
                    workspace_label=workspace_label,
                )
            )
        if mode_hint and not file_ops:
            response_parts.append(mode_hint)
        final_text = "\n\n".join(part for part in response_parts if part).strip() or "Done."

        memory_text = visible_response if file_ops else cleaned_response
        memory_parts = [memory_text] if memory_text else []
        if file_ops:
            memory_parts.append(
                bot._render_file_operations(
                    file_ops,
                    include_diffs=False,
                    workspace_label=workspace_label,
                )
            )
        memory_response = "\n\n".join(part for part in memory_parts if part).strip() or "Done."
        bot.memory.ingest("assistant", memory_response, session_id)

        if not provider_error_response:
            await bot.maybe_summarize(session_id)
        return final_text

    def _render_terminal_reply(text: str, parse_mode: str | None = None):
        rendered = bot._strip_html_for_log(text) if parse_mode else text
        print(f"机器人> {rendered}\n")

    class _CliSentMessage:
        def __init__(self):
            self.text = ""

        async def edit_text(self, text: str, parse_mode: str | None = None):
            _render_terminal_reply(text, parse_mode=parse_mode)
            self.text = text
            return self

    class _CliIncomingMessage:
        def __init__(self, text: str):
            self.text = text

        async def reply_text(self, text: str, parse_mode: str | None = None):
            _render_terminal_reply(text, parse_mode=parse_mode)
            sent = _CliSentMessage()
            sent.text = text
            return sent

    class _CliBotAPI:
        async def send_chat_action(self, chat_id, action):
            return None

    class _CliContext:
        def __init__(self, args_list: list[str]):
            self.args = args_list
            self.bot = _CliBotAPI()

    async def _run_terminal_command(raw_line: str) -> bool:
        if raw_line.lower() in {"/exit", "/quit"}:
            print("再见。")
            return True

        try:
            parts = shlex.split(raw_line[1:])
        except ValueError as e:
            print(f"机器人> ⚠️ 无效的命令语法: {e}\n")
            return False

        if not parts:
            return False

        command = parts[0].lower()
        args_list = parts[1:]

        handler_map = {
            "start": bot.cmd_start,
            "help": bot.cmd_help,
            "clear": bot.cmd_clear,
            "wipe_memory": bot.cmd_wipe_memory,
            "wipe": bot.cmd_wipe_memory,
            "memory": bot.cmd_memory,
            "recall": bot.cmd_recall,
            "skills": bot.cmd_skills,
            "agent": bot.cmd_agent,
            "mode": bot.cmd_mode,
            "heartbeat": bot.cmd_heartbeat,
            "cron": bot.cmd_cron,
            "show": bot.cmd_show,
        }
        handler = handler_map.get(command)
        if not handler:
            print("机器人> 未知命令。输入 /help 查看可用命令。\n")
            return False

        class _CliUpdate:
            def __init__(self, line_text: str):
                self.effective_user = type("U", (), {"id": cli_user_id})()
                self.effective_chat = type("C", (), {"id": session_id})()
                self.message = _CliIncomingMessage(line_text)

        update = _CliUpdate(raw_line)
        context = _CliContext(args_list)
        await handler(update, context)
        return False

    while True:
        try:
            user_text = input("你> ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n再见。")
            return 0

        if not user_text:
            continue

        pending_multi = bot._get_pending_multi_plan(session_id)
        if pending_multi and not user_text.startswith("/"):
            decision = bot._classify_pending_multi_reply(user_text)
            if decision == "confirm":
                try:
                    should_exit = asyncio.run(_run_terminal_command("/agent multi confirm"))
                except Exception as e:
                    print(f"机器人> ⚠️ 命令失败: {e}\n")
                    should_exit = False
                if should_exit:
                    return 0
                continue
            if decision == "cancel":
                try:
                    should_exit = asyncio.run(_run_terminal_command("/agent multi cancel"))
                except Exception as e:
                    print(f"机器人> ⚠️ 命令失败: {e}\n")
                    should_exit = False
                if should_exit:
                    return 0
                continue
            reminder = bot._render_pending_multi_reminder(session_id)
            print(f"机器人> {bot._strip_html_for_log(reminder)}\n")
            continue

        if user_text.startswith("/"):
            try:
                should_exit = asyncio.run(_run_terminal_command(user_text))
            except Exception as e:
                print(f"bot> ⚠️ Command failed: {e}\n")
                should_exit = False
            if should_exit:
                return 0
            continue

        try:
            reply = asyncio.run(_chat_once(user_text))
        except Exception as e:
            reply = f"⚠️ Internal error: {e}"
        print(f"机器人> {reply}\n")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="CodeClaw", description="CodeClaw CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    onboard = sub.add_parser("onboard", help="在用户主目录初始化 .env 和运行时工作区")
    onboard.add_argument("--home", help="目标运行时主目录（默认值：用户主目录）")
    onboard.add_argument(
        "--force",
        action="store_true",
        help="覆盖现有的 .env 和运行时模板",
    )
    onboard.add_argument(
        "--reset-env",
        action="store_true",
        help="从模板重置现有的 .env，但不覆盖运行时模板",
    )
    onboard.add_argument(
        "--configure",
        action="store_true",
        help="使用当前的 .env 运行引导式提供商/令牌配置",
    )
    onboard.set_defaults(func=cmd_onboard)

    run = sub.add_parser(
        "run",
        help="使用用户主目录作为运行时主目录运行 CodeClaw",
        description=(
            "运行 CodeClaw。\n"
            "如果省略了 --provider/--model 且连接了 TTY，"
            "你可以从配置的凭证中交互式地选择提供商/模型。"
        ),
    )
    run.add_argument("--home", help="运行时主目录（默认值：用户主目录）")
    run.add_argument(
        "--provider",
        help="为此运行覆盖提供商 (openai|xai|claude|gemini|deepseek|zai)",
    )
    run.add_argument(
        "--model",
        help="为此运行覆盖模型（与当前/覆盖的提供商一起使用）",
    )
    run.set_defaults(func=cmd_run)

    chat = sub.add_parser(
        "chat",
        help="运行本地终端聊天会话",
        description=(
            "使用 CodeClaw 运行终端聊天。\n"
            "使用与 Telegram 相同的内存数据库/工作区/提供商栈。"
        ),
    )
    chat.add_argument("--home", help="运行时主目录（默认值：用户主目录）")
    chat.add_argument(
        "--provider",
        help="为此会话覆盖提供商 (openai|xai|claude|gemini|deepseek|zai)",
    )
    chat.add_argument(
        "--model",
        help="为此会话覆盖模型（与当前/覆盖的提供商一起使用）",
    )
    chat.add_argument(
        "--session",
        default="cli",
        help="终端内存的会话 ID（默认值：cli）",
    )
    chat.set_defaults(func=cmd_chat)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
